[core]
    autocrlf = input
    editor = subl -w
    excludesfile = /Users/Simen/.gitignore
	quotepath = false
	ignorecase = false
[user]
    name = Simen Brekken
    email = simen@unfold.no
[credential]
    helper = osxkeychain
[alias]
    b = branch
    c = commit --verbose
    l = log --pretty=oneline --abbrev-commit
    s = status
    co = checkout
    rb = rebase --interactive
    up = "!git remote update -p; git merge --ff-only @{u}"
    start = checkout -b
    stop = "!export feature_branch=`git rev-parse --abbrev-ref HEAD`; [[ $feature_branch == 'master' ]] && echo 'Cannot merge master' && exit 1; git checkout master && git merge --no-ff $feature_branch"
    resume = "!git checkout $1 && git rebase master"
    finish = "!export feature_branch=`git rev-parse --abbrev-ref HEAD`; git stop && git branch -d $feature_branch"
[mergetool]
    keepBackup = false
[push]
    default = upstream
[branch]
    autosetuprebase = always
[color]
    branch = auto
    diff = auto
    status = auto
    ui = auto
[log]
    decorate = short
